/* ============================================
   V3RSUS — MMA Predictive Analytics
   ============================================ */

:root {
    --bg-dark: #080a10;
    --bg-card: rgba(12, 16, 26, 0.65);
    --border-subtle: rgba(255, 255, 255, 0.06);
    --border-hover: rgba(255, 255, 255, 0.12);
    --glass-blur: blur(20px);

    --red-accent: #ef4444;
    --red-glow: rgba(239, 68, 68, 0.4);
    --red-bg: rgba(239, 68, 68, 0.08);
    --red-border: rgba(239, 68, 68, 0.18);

    --blue-accent: #3b82f6;
    --blue-glow: rgba(59, 130, 246, 0.4);
    --blue-bg: rgba(59, 130, 246, 0.08);
    --blue-border: rgba(59, 130, 246, 0.18);

    --text-primary: #f0f0f8;
    --text-muted: rgba(240, 240, 248, 0.45);
    --text-dim: rgba(240, 240, 248, 0.25);

    --shadow-card: 0 24px 80px rgba(0, 0, 0, 0.5), 0 0 60px rgba(59, 130, 246, 0.06);
    --radius: 16px;
    --radius-lg: 24px;
}

/* ---- Reset ---- */
*, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html {
    scroll-behavior: smooth;
}

/* ---- Body ---- */
body {
    background: var(--bg-dark);
    color: var(--text-primary);
    font-family: 'Barlow', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
}

body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
        radial-gradient(ellipse 80% 50% at 50% -10%, rgba(240, 240, 248, 0.04) 0%, transparent 60%),
        radial-gradient(circle 600px at 15% 85%, rgba(240, 240, 248, 0.015) 0%, transparent 70%),
        radial-gradient(circle 500px at 90% 70%, rgba(240, 240, 248, 0.012) 0%, transparent 70%);
    z-index: 0;
    pointer-events: none;
}


/* ============================================
   BACK LINK
   ============================================ */
.back-link {
    position: fixed;
    top: 1.25rem;
    left: 1.5rem;
    z-index: 1000;
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 100px;
    background: rgba(8, 10, 16, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border-subtle);
    transition: color 0.25s ease, border-color 0.25s ease;
}

.back-link:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
}

/* ============================================
   TOP BAR (scroll-reveal)
   ============================================ */
.top-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1.5rem;
    background: rgba(8, 10, 16, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    opacity: 0;
    transform: translateY(-100%);
    transition: opacity 0.4s ease, transform 0.4s ease;
    pointer-events: none;
    will-change: transform, opacity;
}

.top-bar.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
}

.top-bar-left {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
}

.top-bar-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border: 1px solid var(--text-primary);
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 9px;
    letter-spacing: 0.08em;
    color: var(--text-primary);
    text-transform: uppercase;
    line-height: 1;
}

.top-bar-identity {
    display: flex;
    flex-direction: column;
    line-height: 1;
}

.top-bar-brand {
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.25em;
    color: var(--text-primary);
    text-transform: uppercase;
}

.top-bar-byline {
    margin-top: 2px;
    font-family: 'Barlow', sans-serif;
    font-size: 0.5rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: rgba(240, 240, 248, 0.25);
}

.top-bar-links {
    display: flex;
    gap: 1.5rem;
}

.top-bar-links a {
    font-family: 'Oswald', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(240, 240, 248, 0.4);
    text-decoration: none;
    transition: color 0.25s ease;
}

.top-bar-links a:hover {
    color: var(--text-primary);
}

/* ============================================
   HERO
   ============================================ */
.hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 100svh;
    padding: 4rem 2rem;
    position: relative;
    z-index: 10;
    overflow: hidden;
}

/* ---- Entrance animations ---- */
@keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
}

@keyframes monogramFloat {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-12px) scale(1.005); }
}

/* Stagger classes */
.stagger-1 { animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards; opacity: 0; }
.stagger-2 { animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards; opacity: 0; }
.stagger-3 { animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.35s forwards; opacity: 0; }
.stagger-4 { animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards; opacity: 0; }

/* Background monogram */
.monogram-bg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    overflow: hidden;
}

.monogram {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(300px, 45vw, 700px);
    font-weight: 900;
    line-height: 0.85;
    color: transparent;
    -webkit-text-stroke: 1px rgba(240, 240, 248, 0.025);
    user-select: none;
    animation: monogramFloat 8s ease-in-out infinite;
    will-change: transform;
}

/* Foreground content */
.hero-content {
    position: relative;
    z-index: 10;
}

.hero-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(240, 240, 248, 0.45);
}

.hero-title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(6rem, 14vw, 14rem);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1;
    color: var(--text-primary);
    margin-top: 0.5rem;
}

.hero-sub {
    font-family: 'Oswald', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    color: rgba(240, 240, 248, 0.45);
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
    max-width: 28rem;
    margin: 0.75rem auto 0;
    line-height: 1.6;
}

.hero-ctas {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2.5rem;
}

/* Pill buttons */
.pill-btn {
    font-family: 'Oswald', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.7rem 2.2rem;
    border: 1px solid rgba(240, 240, 248, 0.12);
    border-radius: 100px;
    background: transparent;
    color: rgba(240, 240, 248, 0.55);
    transition: all 0.25s ease;
}

.pill-btn:hover {
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(240, 240, 248, 0.22);
    color: var(--text-primary);
}

.pill-btn:active {
    transform: scale(0.98);
}

.pill-btn-filled {
    font-family: 'Oswald', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.7rem 2.2rem;
    border: 1px solid rgba(240, 240, 248, 0.85);
    border-radius: 100px;
    background: rgba(240, 240, 248, 0.85);
    color: #0a0a0f;
    transition: all 0.25s ease;
}

.pill-btn-filled:hover {
    background: rgba(240, 240, 248, 0.95);
    box-shadow: 0 0 30px -4px rgba(240, 240, 248, 0.15);
    transform: translateY(-1px);
}

.pill-btn-filled:active {
    transform: translateY(0) scale(0.98);
}

/* Ambient orbs */
.ambient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    animation: monogramFloat 8s ease-in-out infinite;
    will-change: transform;
}

/* Legacy cta-btn kept for predict section */
.cta-btn {
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.75rem 2.5rem;
    border-radius: 100px;
    transition: color 0.3s ease, border-color 0.3s ease;
}


.cta-btn:focus-visible,
.pill-btn:focus-visible,
.pill-btn-filled:focus-visible,
.primary-btn:focus-visible {
    outline: 2px solid var(--text-primary);
    outline-offset: 2px;
}

/* ============================================
   PAGE & SECTIONS
   ============================================ */
.page {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 10;
}

.section {
    padding: 2rem 1rem 4rem;
}

.reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
}

.reveal.visible {
    opacity: 1;
    transform: translateY(0);
}

.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }

/* ---- Glass Panel ---- */
.glass-panel {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius);
    padding: 2.5rem;
    transition: border-color 0.3s ease;
}

.glass-panel:hover {
    border-color: rgba(255, 255, 255, 0.1);
}

.section-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.6rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: rgba(240, 240, 248, 0.25);
    margin-bottom: 1.8rem;
    text-align: center;
}

.section-desc {
    font-size: 0.65rem;
    color: rgba(240, 240, 248, 0.2);
    text-align: center;
    margin-top: -1.2rem;
    margin-bottom: 1.5rem;
}

/* ============================================
   PREDICTIVE ENGINE
   ============================================ */
.predict-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100svh;
    padding: 4rem 1rem;
    position: relative;
    z-index: 10;
}

.predict-inner {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
}

.matchup-container {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 2rem;
    align-items: end;
    position: relative;
    z-index: 2;
}

.fighter-panel {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.fighter-panel label {
    font-family: 'Oswald', sans-serif;
    font-weight: 400;
    text-transform: uppercase;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: rgba(240, 240, 248, 0.25);
}

/* ---- Inputs ---- */
.input-wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
}

input[type="text"] {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    padding: 1rem 0;
    color: var(--text-primary);
    font-family: 'Oswald', sans-serif;
    font-size: 1.6rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    outline: none;
    border-radius: 0;
    transition: border-color 0.3s ease;
}

input[type="text"]::placeholder {
    color: rgba(240, 240, 248, 0.12);
    font-weight: 400;
}

input[type="text"]:focus {
    border-color: rgba(240, 240, 248, 0.4);
}

/* ---- Autocomplete ---- */
.autocomplete-list {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    width: 100%;
    background: rgba(12, 16, 26, 0.95);
    border: 1px solid var(--border-subtle);
    border-radius: 10px;
    max-height: 200px;
    overflow-y: auto;
    z-index: 200;
    list-style: none;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
}

.autocomplete-list li {
    padding: 0.75rem 1rem;
    cursor: pointer;
    font-size: 0.88rem;
    color: var(--text-muted);
    transition: background 0.15s ease, color 0.15s ease;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
}

.autocomplete-list li:last-child { border-bottom: none; }

.autocomplete-list li:hover,
.autocomplete-list li.active {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-primary);
}

.autocomplete-list li strong {
    color: var(--text-primary);
    font-weight: 600;
}

/* ---- VS Badge ---- */
.vs-badge {
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 1rem;
}

.vs-badge span {
    font-family: 'Oswald', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    color: rgba(240, 240, 248, 0.2);
}

/* ---- Action Bar & Button ---- */
.action-bar {
    margin-top: 3.5rem;
    display: flex;
    justify-content: center;
    position: relative;
    z-index: 1;
}

.primary-btn {
    background: transparent;
    color: rgba(240, 240, 248, 0.6);
    font-family: 'Oswald', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0.85rem 3rem;
    border: 1px solid rgba(240, 240, 248, 0.25);
    border-radius: 100px;
    cursor: pointer;
    transition: color 0.3s ease, border-color 0.3s ease;
    position: relative;
    overflow: hidden;
}

.primary-btn:hover {
    color: var(--text-primary);
    border-color: rgba(240, 240, 248, 0.6);
}

.primary-btn:disabled {
    opacity: 0.4;
    cursor: default;
}

/* ---- Loader ---- */
.loader {
    width: 16px;
    height: 16px;
    border: 1.5px solid rgba(240, 240, 248, 0.15);
    border-top: 1.5px solid rgba(240, 240, 248, 0.6);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    display: inline-block;
    vertical-align: middle;
}

.hidden { display: none !important; }

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

/* ============================================
   RESULT SECTION
   ============================================ */
.result-section {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 0 1rem 4rem;
}

.result-section > * {
    animation: fadeInUp 0.5s cubic-bezier(0, 0, 0.2, 1) both;
}
.result-section > *:nth-child(1)  { animation-delay: 0.05s; }
.result-section > *:nth-child(2)  { animation-delay: 0.10s; }
.result-section > *:nth-child(3)  { animation-delay: 0.15s; }
.result-section > *:nth-child(4)  { animation-delay: 0.20s; }
.result-section > *:nth-child(5)  { animation-delay: 0.25s; }
.result-section > *:nth-child(6)  { animation-delay: 0.30s; }
.result-section > *:nth-child(7)  { animation-delay: 0.35s; }
.result-section > *:nth-child(8)  { animation-delay: 0.40s; }
.result-section > *:nth-child(9)  { animation-delay: 0.45s; }
.result-section > *:nth-child(10) { animation-delay: 0.50s; }

@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* Color utilities */
.red-text  { color: rgba(240, 240, 248, 0.7); }
.blue-text { color: rgba(240, 240, 248, 0.4); }

/* ---- Probability Card ---- */
.prob-card { text-align: center; }

.prob-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
}

.prob-header:last-of-type {
    margin-bottom: 0;
    margin-top: 0.6rem;
}

.prob-name {
    font-family: 'Oswald', sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
}

.prob-pct {
    font-family: 'Oswald', sans-serif;
    font-weight: 500;
    font-size: 1.3rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
}

.prob-bar {
    display: flex;
    height: 3px;
    border-radius: 3px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
    gap: 2px;
}

.prob-fill {
    height: 100%;
    transition: width 1s cubic-bezier(0.16, 1, 0.3, 1);
    border-radius: 3px;
}

.red-fill {
    background: rgba(240, 240, 248, 0.6);
}

.blue-fill {
    background: rgba(240, 240, 248, 0.2);
}

.winner-indicator {
    display: flex;
    align-items: center;
    gap: 0.4rem;
}

.winner-name-text {
    font-family: 'Oswald', sans-serif;
    font-weight: 500;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(240, 240, 248, 0.5);
    white-space: nowrap;
}

.winner-arrow {
    font-size: 0.55rem;
    color: var(--text-dim);
    display: none;
}

.winner-arrow.active {
    display: inline;
    color: var(--text-muted);
}

/* ============================================
   KEY FACTORS (NEW)
   ============================================ */
.factors-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.factor-row {
    padding: 0.9rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.factor-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
}

.factor-name {
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(240, 240, 248, 0.5);
}

.factor-cat {
    font-family: 'Oswald', sans-serif;
    font-size: 0.5rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.12rem 0.45rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: transparent;
    color: rgba(240, 240, 248, 0.25);
}

.factor-bottom {
    display: flex;
    align-items: center;
    gap: 0.6rem;
}

.factor-val {
    font-family: 'Barlow', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--text-muted);
    min-width: 2.5rem;
    text-align: center;
}

.factor-bar-wrap {
    flex: 1;
    height: 2px;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.04);
    overflow: hidden;
}

.factor-bar {
    height: 100%;
    border-radius: 2px;
    transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    background: rgba(240, 240, 248, 0.3);
}

.factor-adv {
    font-family: 'Oswald', sans-serif;
    font-size: 0.55rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 0.35rem;
    text-align: right;
    color: rgba(240, 240, 248, 0.25);
}

/* ============================================
   EDGE ANALYSIS (NEW)
   ============================================ */
.edge-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1.2rem;
}

.edge-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.edge-row {
    display: grid;
    grid-template-columns: 100px 1fr 40px;
    gap: 0.75rem;
    align-items: center;
}

.edge-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
}

.edge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    opacity: 0.4;
}

.edge-name {
    font-family: 'Oswald', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(240, 240, 248, 0.35);
}

.edge-bar-container {
    position: relative;
    height: 3px;
}

.edge-bar-track {
    display: flex;
    height: 100%;
    border-radius: 3px;
    overflow: hidden;
    gap: 1px;
}

.edge-fill-left {
    height: 100%;
    border-radius: 3px 0 0 3px;
    background: rgba(240, 240, 248, 0.5);
    transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.edge-fill-right {
    height: 100%;
    border-radius: 0 3px 3px 0;
    background: rgba(240, 240, 248, 0.15);
    transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.edge-midline {
    position: absolute;
    left: 50%;
    top: -2px;
    bottom: -2px;
    width: 1px;
    background: rgba(255, 255, 255, 0.1);
    pointer-events: none;
}

.edge-score {
    font-family: 'Oswald', sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    font-variant-numeric: tabular-nums;
    text-align: right;
    color: rgba(240, 240, 248, 0.3);
}

/* ============================================
   FIGHTER PROFILES
   ============================================ */
.profiles-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
}

.profile-card { padding: 1.5rem; }
.red-tint { border-color: rgba(255, 255, 255, 0.08); }
.blue-tint { border-color: rgba(255, 255, 255, 0.05); }

.profile-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.5rem;
}

.profile-name {
    font-family: 'Oswald', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    color: var(--text-primary);
}

.profile-record {
    font-family: 'Barlow', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    color: var(--text-muted);
}

.profile-meta {
    display: flex;
    gap: 0.4rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
}

.meta-tag {
    font-family: 'Oswald', sans-serif;
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.18rem 0.5rem;
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border-subtle);
    color: var(--text-dim);
}

.stat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
}

.stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
}

.stat-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.58rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-dim);
}

.stat-value {
    font-family: 'Barlow', sans-serif;
    font-size: 0.92rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    color: var(--text-primary);
}

/* ============================================
   HEAD-TO-HEAD COMPARISON
   ============================================ */
.comparison-card { padding-bottom: 2rem; }

.comparison-rows {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.cmp-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.75rem;
    align-items: center;
}

.cmp-val {
    font-family: 'Barlow', sans-serif;
    font-weight: 600;
    font-size: 0.88rem;
    font-variant-numeric: tabular-nums;
    color: var(--text-primary);
}

.cmp-val.left { text-align: right; }
.cmp-val.right { text-align: left; }
.cmp-val.advantage { color: #fff; }

.cmp-center {
    text-align: center;
    min-width: 100px;
}

.cmp-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
}

.cmp-bar-wrap {
    display: flex;
    height: 3px;
    border-radius: 3px;
    overflow: hidden;
    gap: 2px;
    margin-top: 0.25rem;
}

.cmp-bar-left, .cmp-bar-right {
    height: 100%;
    border-radius: 3px;
    opacity: 0.5;
    transition: width 0.8s ease, opacity 0.3s ease;
}

.cmp-bar-left { background: rgba(240, 240, 248, 0.5); }
.cmp-bar-right { background: rgba(240, 240, 248, 0.2); }
.cmp-bar-left.lead { opacity: 1; }
.cmp-bar-right.lead { opacity: 1; }

/* ============================================
   WIN METHOD BREAKDOWN
   ============================================ */
.method-card { text-align: center; }

.method-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 1.5rem;
    align-items: start;
}

.method-col {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
}

.method-labels {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
}

.method-row-label {
    font-family: 'Oswald', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.method-bar-wrap {
    height: 28px;
    display: flex;
    align-items: center;
}

.method-bar-wrap.left { justify-content: flex-end; }
.method-bar-wrap.right { justify-content: flex-start; }

.method-bar {
    height: 16px;
    border-radius: 4px;
    min-width: 2px;
    transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    display: flex;
    align-items: center;
}

.method-bar.red-bar {
    background: rgba(240, 240, 248, 0.35);
    justify-content: flex-start;
    padding-left: 0.4rem;
}

.method-bar.blue-bar {
    background: rgba(240, 240, 248, 0.15);
    justify-content: flex-end;
    padding-right: 0.4rem;
}

.method-count {
    font-family: 'Barlow', sans-serif;
    font-size: 0.6rem;
    font-weight: 500;
    color: rgba(240, 240, 248, 0.7);
    font-variant-numeric: tabular-nums;
}

/* ============================================
   MODEL CONSENSUS (NEW)
   ============================================ */
.models-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1rem;
}

.models-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.model-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.4rem;
    padding: 0.7rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.model-ensemble {
    border-bottom-color: rgba(255, 255, 255, 0.08);
}

.model-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.model-name {
    font-family: 'Oswald', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(240, 240, 248, 0.4);
}

.model-ensemble .model-name {
    color: rgba(240, 240, 248, 0.7);
}

.model-acc {
    font-family: 'Barlow', sans-serif;
    font-size: 0.6rem;
    font-weight: 400;
    color: rgba(240, 240, 248, 0.2);
}

.model-bar-wrap {
    height: 2px;
    border-radius: 2px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
}

.model-bar {
    display: flex;
    height: 100%;
    gap: 1px;
}

.model-fill {
    height: 100%;
    transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.model-fill:first-child { border-radius: 2px 0 0 2px; }
.model-fill:last-child { border-radius: 0 2px 2px 0; }

.model-probs {
    display: flex;
    justify-content: space-between;
}

.model-prob {
    font-family: 'Barlow', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
}

/* ============================================
   HISTORICAL MATCHUPS (NEW)
   ============================================ */
.history-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.history-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.7rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.history-date {
    font-family: 'Barlow', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-dim);
    font-variant-numeric: tabular-nums;
}

.history-result {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-align: right;
}

.history-winner {
    font-family: 'Oswald', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
}

.history-method {
    font-family: 'Barlow', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--text-dim);
}



/* ============================================
   SCROLLBAR & SELECTION
   ============================================ */
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: rgba(255, 255, 255, 0.02); }
::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.18); }
::selection { background: rgba(59, 130, 246, 0.3); color: #fff; }

/* ============================================
   ABOUT PAGE
   ============================================ */
.about-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100svh;
    padding: 6rem 2rem 4rem;
    position: relative;
    z-index: 10;
}

.about-content {
    max-width: 440px;
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
}

.about-name {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-primary);
    line-height: 1;
    margin-bottom: 0.6rem;
    animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
    opacity: 0;
}

.about-role {
    font-family: 'Oswald', sans-serif;
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: rgba(240, 240, 248, 0.3);
    margin-bottom: 2rem;
    animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
    opacity: 0;
}

.about-divider {
    width: 32px;
    height: 1px;
    background: rgba(240, 240, 248, 0.1);
    margin-bottom: 2rem;
    animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.25s forwards;
    opacity: 0;
}

.about-bio {
    font-family: 'Barlow', sans-serif;
    font-size: 0.88rem;
    font-weight: 400;
    line-height: 1.8;
    color: rgba(240, 240, 248, 0.45);
    margin-bottom: 2.5rem;
    animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.35s forwards;
    opacity: 0;
}

.about-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.5s forwards;
    opacity: 0;
}

.about-links a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Oswald', sans-serif;
    font-size: 0.6rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(240, 240, 248, 0.4);
    padding: 0.6rem 1.8rem;
    border: 1px solid rgba(240, 240, 248, 0.1);
    border-radius: 100px;
    transition: all 0.25s ease;
}

.about-links a:hover {
    color: var(--text-primary);
    border-color: rgba(240, 240, 248, 0.3);
    box-shadow: 0 0 20px -4px rgba(240, 240, 248, 0.06);
}

.about-links svg {
    flex-shrink: 0;
}


/* ============================================
   RESPONSIVE
   ============================================ */
@media (max-width: 768px) {
    .hero {
        padding: 3rem 1.5rem;
        min-height: 100svh;
    }

    .monogram {
        font-size: clamp(200px, 55vw, 400px);
    }

    .hero-title {
        font-size: clamp(4rem, 18vw, 8rem);
    }


    .glass-panel { padding: 1.5rem; }

    .predict-page { min-height: 100svh; padding: 3rem 1rem; }

    .hero-ctas {
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
    }

    .matchup-container {
        grid-template-columns: 1fr;
        gap: 0.25rem;
    }

    .vs-badge { padding-bottom: 0; }

    input[type="text"] { font-size: 1.2rem; }

    .action-bar { margin-top: 2.5rem; }
    .profiles-grid { grid-template-columns: 1fr; }
    .method-grid { gap: 0.75rem; }
    .cmp-center { min-width: 70px; }
    .prob-pct { font-size: 1rem; }
    .winner-name-text { font-size: 0.6rem; }
    .result-section { padding: 0 1rem 3rem; }

    .edge-row {
        grid-template-columns: 80px 1fr 32px;
        gap: 0.5rem;
    }

    .history-row {
        flex-direction: column;
        gap: 0.3rem;
        text-align: center;
    }

    .history-result {
        flex-direction: column;
        gap: 0.2rem;
        text-align: center;
    }

    .methodology-section { padding: 2.5rem 1rem 3rem; }
    .method-container { max-width: 100%; }
    .toc-list { columns: 1; }
    .method-table { font-size: 0.72rem; }
    .method-table th, .method-table td { padding: 0.4rem 0.5rem; }
    .method-toc { padding: 1rem 1.2rem; }

    .about-page { padding: 5rem 1.5rem 2rem; }
}
